{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dfx-assessment.schema.json",
  "title": "DFX 12x4 Assessment",
  "type": "object",
  "required": ["dimensions", "elements"],
  "additionalProperties": false,
  "properties": {
    "dimensions": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["dimension", "status", "reason", "scenarios"],
        "additionalProperties": false,
        "properties": {
          "dimension": {"type": "string", "minLength": 1},
          "status": {"enum": ["适用", "不适用", "待确认", "需补充证据"]},
          "reason": {"type": "string", "minLength": 1},
          "scenarios": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["interaction_id", "function_point", "assessments"],
        "additionalProperties": false,
        "properties": {
          "interaction_id": {"type": "string", "minLength": 1},
          "function_point": {"type": "string", "minLength": 1},
          "assessments": {
            "type": "array",
            "minItems": 12,
            "maxItems": 12,
            "items": {
              "type": "object",
              "required": ["dimension", "scenarios"],
              "additionalProperties": false,
              "properties": {
                "dimension": {"type": "string", "minLength": 1},
                "scenarios": {
                  "type": "array",
                  "minItems": 4,
                  "maxItems": 4,
                  "items": {
                    "type": "object",
                    "required": ["scenario", "status", "reason", "planned_case_ids"],
                    "additionalProperties": false,
                    "properties": {
                      "scenario": {"type": "string", "minLength": 1},
                      "status": {"enum": ["适用", "不适用", "待确认", "需补充证据"]},
                      "reason": {"type": "string", "minLength": 1},
                      "planned_case_ids": {
                        "type": "array",
                        "items": {"type": "string", "minLength": 1},
                        "uniqueItems": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$comment": "The deterministic gate requires a global 12x4 summary and a complete 12x4 assessment for every element interaction; applicable scenarios must account for the exact plan case budget."
}
