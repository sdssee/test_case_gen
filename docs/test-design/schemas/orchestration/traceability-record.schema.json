{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "traceability-record.schema.json",
  "title": "Test Case Traceability Record",
  "type": "object",
  "required": [
    "schema_version", "case_id", "function_point", "plan_owner_id", "interaction_ids",
    "selection_observation_ids", "branch_observation_ids", "lifecycle_ids", "evidence_hashes",
    "worker_task_id", "source_fingerprint"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "case_id": {"$ref": "#/$defs/identifier"},
    "function_point": {"type": "string", "minLength": 1, "pattern": "^(?:\\S(?:.*\\S)?)$"},
    "plan_owner_id": {"$ref": "#/$defs/identifier"},
    "interaction_ids": {"$ref": "#/$defs/uniqueStrings"},
    "selection_observation_ids": {"$ref": "#/$defs/uniqueStrings"},
    "branch_observation_ids": {"$ref": "#/$defs/uniqueStrings"},
    "lifecycle_ids": {"$ref": "#/$defs/uniqueStrings"},
    "evidence_hashes": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/fingerprint"}
    },
    "worker_task_id": {"$ref": "#/$defs/identifier"},
    "source_fingerprint": {"$ref": "#/$defs/fingerprint"}
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uniqueStrings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "pattern": "^(?:\\S(?:.*\\S)?)$"}
    }
  }
}
