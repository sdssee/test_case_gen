{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rework-request.schema.json",
  "title": "Test Design Rework Request",
  "type": "object",
  "required": [
    "schema_version", "request_id", "run_id", "batch_id", "target_phase", "target_task_id",
    "reason_code", "affected_ids", "evidence", "required_action", "source_fingerprint", "attempt"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "request_id": {"$ref": "#/$defs/identifier"},
    "run_id": {"$ref": "#/$defs/scopeIdentifier"},
    "batch_id": {"$ref": "#/$defs/scopeIdentifier"},
    "target_phase": {"enum": ["discovery", "plan", "risk", "cases", "review", "delivery"]},
    "target_task_id": {
      "oneOf": [
        {"$ref": "#/$defs/identifier"},
        {"type": "null"}
      ]
    },
    "reason_code": {
      "enum": [
        "ELEMENT_NOT_EXECUTED", "SELECTION_OPTION_MISSING", "CRUD_EFFECT_UNVERIFIED",
        "PAGE_VERIFIABLE_RISK", "EXTERNAL_SEMANTICS_REQUIRED", "DFX_GAP",
        "CASE_BUDGET_INSUFFICIENT", "DUPLICATE_STEPS", "DUPLICATE_EXPECTED_RESULT",
        "FUNCTION_POINT_DRIFT", "TRACEABILITY_GAP", "DELIVERY_MISMATCH", "SOURCE_CHANGED",
        "AGENT_OUTPUT_INVALID"
      ]
    },
    "affected_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "pattern": "^(?:\\S(?:.*\\S)?)$"}
    },
    "evidence": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/evidencePath"}
    },
    "required_action": {"type": "string", "minLength": 1, "pattern": "^(?:\\S(?:.*\\S)?)$"},
    "source_fingerprint": {"$ref": "#/$defs/fingerprint"},
    "attempt": {"type": "integer", "minimum": 1}
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "scopeIdentifier": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[^/\\\\\\u0000]+$", "not": {"enum": [".", ".."]}},
    "fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidencePath": {
      "type": "string",
      "pattern": "^artifacts/(?:evidence|screenshots|data|agent-work)/[^\\\\]+$",
      "not": {"pattern": "(?:^|/)(?:\\.|\\.\\.)(?:/|$)"}
    }
  }
}
